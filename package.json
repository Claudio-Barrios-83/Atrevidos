{
	"name": "atrevidos",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node build",
		"check": "svelte-kit sync && npx tsc --noEmit",
		"check:svelte": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write .",
		"test": "vitest run --run --reporter=verbose",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.21.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.1",
		"@types/eslint": "^9.6.1",
		"@types/jest": "^30.0.0",
		"@types/jsdom": "^28.0.3",
		"@types/node": "^22.20.0",
		"@types/ws": "^8.18.1",
		"@typescript-eslint/eslint-plugin": "^8.60.1",
		"@typescript-eslint/parser": "^8.60.1",
		"autoprefixer": "^10.4.20",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.6",
		"eslint-plugin-svelte": "^3.19.0",
		"jsdom": "^29.1.1",
		"postcss": "^8.5.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.1.4",
		"tailwindcss": "^3.4.17",
		"typescript": "^5.7.3",
		"typescript-eslint": "^8.62.0",
		"vite": "^6.2.0",
		"vitest": "^4.1.8",
		"ws": "^8.21.0"
	},
	"dependencies": {
		"@supabase/auth-helpers-sveltekit": "^0.14.0",
		"@supabase/ssr": "^0.12.0",
		"@supabase/supabase-js": "^2.49.4",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.0.1"
	},
	"engines": {
		"node": ">=18.13"
	},
	"type": "module"
}
